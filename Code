// Dino game code with fixes applied

const canvas = document.getElementById('gameCanvas');
const ctx = canvas.getContext('2d');

const dinoImage = new Image();
dinoImage.src = 'dino.png';

const dinoInitialState = {
    x: 50,
    y: canvas.height - 100,
    dy: 0,
    grounded: true
};

let dinoState = {...dinoInitialState};

function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.drawImage(dinoImage, dinoState.x, dinoState.y);
}

function update() {
    if (!dinoState.grounded) {
        dinoState.dy += 1; // Gravity
    }
    dinoState.y += dinoState.dy;
    if (dinoState.y >= canvas.height - 100) {
        dinoState.y = canvas.height - 100;
        dinoState.grounded = true;
    }
    draw();
}

function restartGame() {
    dinoState = {...dinoInitialState};
    update(); // initial draw call after reset
}

// Event listeners and game loop can be added here

function gameLoop() {
    update();
    requestAnimationFrame(gameLoop);
}

// Start the game
restartGame();
gameLoop();